<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="artifactory" value="%ARTIFACTORY_NUGET_SOURCE_URL%" />
  </packageSources>
  <disabledPackageSources>
    <add key="artifactory" value="true" />
  </disabledPackageSources>
  <packageSourceCredentials>
    <artifactory>
      <add key="Username" value="%ARTIFACTORY_NUGET_USERNAME%" />
      <add key="ClearTextPassword" value="%ARTIFACTORY_NUGET_AUTH_TOKEN%" />
    </artifactory>
  </packageSourceCredentials>
</configuration>
